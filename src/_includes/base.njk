<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "doutrina.org" }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    
    <!-- LEFT SIDEBAR with TOC -->
    <aside class="sidebar">
      <p class="toc-title">
        <span class="emoji">📖</span> Nesta página
      </p>
      
      <div class="toc-tree">
        {{ content | toc | safe }}
      </div>

      <!-- Optional: Keep your other menu items below the TOC -->
      <hr>
      <h4>📚 Livros</h4>
      <!-- Add your book links here if you want them in the sidebar -->
    </aside>

    <!-- MAIN CONTENT -->
    <main>
      {{ content | safe }}
    </main>

    <!-- RIGHT PANEL -->
    <aside class="right-panel">
      <h3>🔍 Info</h3>
      <!-- Your existing right panel content -->
    </aside>

  </div>
</body>
</html>