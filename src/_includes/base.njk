<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "doutrina.org" }}</title>
  <style>
    :root { --accent: #4EC1F5; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      line-height: 1.8;
      margin: 0;
      padding: 0;
      background: #f4f1e9;
    }
    .container {
      display: flex;
      max-width: 1800px;
      margin: 0 auto;
      min-height: 100vh;
    }
    .sidebar {
      width: 280px;
      background: white;
      border-right: 1px solid #ddd;
      padding: 1.5rem;
      overflow-y: auto;
      position: sticky;
      top: 0;
      height: 100vh;
    }
    main {
      flex: 1;
      padding: 2rem 3rem;
      max-width: 820px;
      background: white;
      margin: 1rem 0.5rem;
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .right-panel {
      width: 320px;
      background: white;
      border-left: 1px solid #ddd;
      padding: 1rem;
      overflow-y: auto;
      position: sticky;
      top: 0;
      height: 100vh;
    }
    h1, h2, h3 { color: #1e3a8a; }
    iframe {
      width: 100%;
      height: 85vh;
      border: 1px solid #ddd;
      border-radius: 6px;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Left Sidebar (TOC) -->
    <aside class="sidebar">
      <h3>📖 Nesta página</h3>
      <p><em>Sumário em breve</em></p>
    </aside>

    <!-- Main Content -->
    <main>
      {{ content | safe }}
    </main>

    <!-- Right Panel (Iframe) -->
    <aside class="right-panel">
      <h4>🔍 Ferramentas</h4>
      <iframe src="https://pt.wikipedia.org/wiki/O_Livro_dos_Esp%C3%ADritos" 
              title="Painel Complementar"></iframe>
    </aside>
  </div>
</body>
</html>
