<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "O Livro dos Espíritos - doutrina.org" }}</title>
<link rel="stylesheet" href="/css/style.css">
  <style>
    .container { display: grid; grid-template-columns: 340px 1fr; min-height: 100vh; }
    .sidebar {
      background: #f8f9fa;
      padding: 24px 20px;
      border-right: 1px solid #ddd;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }
    .toc-title { font-weight: bold; margin: 0 0 18px 0; font-size: 1.15rem; }
    .toc-tree details { margin-bottom: 8px; }
       .toc-tree ul { list-style: none; padding-left: 1.3rem; margin: 4px 0; }
    .toc-tree ul ul { padding-left: 1.9rem; }
    .book-content { padding: 40px 50px; max-width: 920px; }
  </style>
</head>
<body>
  <div class="container">
    
    <aside class="sidebar">
    <h1>💧 doutrina.org</h1>
      <p class="toc-title">
        <span class="emoji">📖</span> Nesta página
      </p>
      
      <div class="toc-tree" id="accordion-toc">

        <details>
