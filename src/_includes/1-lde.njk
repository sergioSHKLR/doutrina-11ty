      <hr>
      <h4>📚 Livros</h4>
      <ul>
        <li><a href="/books/1-lde/">👻 O Livro dos Espíritos</a></li>
      </ul>
    </aside>

    <main class="book-content">
      {{ content | safe }}
    </main>
  </div>

  <script>
    // Only one open at a time
    document.querySelectorAll('#accordion-toc details').forEach(detail => {
      detail.addEventListener('toggle', function() {
        if (this.open) {
          document.querySelectorAll('#accordion-toc details').forEach(other => {
            if (other !== this) other.open = false;
          });
        }
      });
    });
  </script>
</body>
</html>